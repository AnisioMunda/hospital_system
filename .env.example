# ============================================================
# HospitalAO — .env (Desenvolvimento Local)
# ============================================================
# ATENÇÃO: Este ficheiro NÃO vai ao Git (.gitignore).
# Contém senhas reais do ambiente de desenvolvimento.
#
# As senhas abaixo foram geradas aleatoriamente.
# Podes usá-las directamente em desenvolvimento.
# Em produção gera novas senhas mais fortes.
# ============================================================


# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
DB_NAME=
DB_USER=
DB_PASSWORD=


# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_PASSWORD=


# ------------------------------------------------------------
# MinIO
# ------------------------------------------------------------
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=


# ------------------------------------------------------------
# RabbitMQ
# ------------------------------------------------------------
RABBITMQ_USER=
RABBITMQ_PASSWORD=


# ------------------------------------------------------------
# JWT
# ------------------------------------------------------------
JWT_SECRET=

# Access token: 15 minutos (em milissegundos)
JWT_EXPIRATION_MS=

# Refresh token: 7 dias (em milissegundos)
JWT_REFRESH_EXPIRATION_MS=


# ------------------------------------------------------------
# Dados do Hospital
# ------------------------------------------------------------
HOSPITAL_NOME=
HOSPITAL_NIF=
HOSPITAL_MORADA=
HOSPITAL_TELEFONE=
HOSPITAL_EMAIL=
HOSPITAL_SERIE_FATURA=


# ------------------------------------------------------------
# Email (deixar vazio em dev — não é necessário agora)
# ------------------------------------------------------------
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=


# ------------------------------------------------------------
# Ambiente
# ------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev