# ============================================================
# HospitalAO — MinIO Configurações Adicionais
# ============================================================
# Estas configurações complementam as variáveis do .env
# principal. São específicas do comportamento do MinIO.
#
# NOTA: As credenciais principais (user/password) estão
# no .env raiz do projecto, não aqui.
# ============================================================

# ----------------------------------------------------------
# Região (compatibilidade com clientes S3)
# ----------------------------------------------------------
# Mesmo sendo local, o MinIO pode simular uma região AWS.
# Usamos "af-south-1" (África do Sul) como mais próxima
# de Angola na nomenclatura AWS.
MINIO_SITE_REGION=af-south-1

# ----------------------------------------------------------
# Nome do site (aparece no painel web)
# ----------------------------------------------------------
MINIO_SITE_NAME=HospitalAO Storage

# ----------------------------------------------------------
# Compressão de objectos
# ----------------------------------------------------------
# Comprimir ficheiros automaticamente ao guardar.
# Reduz o espaço ocupado, especialmente para ficheiros
# de texto como XML do SAFT-AO e JSONs.
MINIO_COMPRESSION_ENABLE=on
MINIO_COMPRESSION_EXTENSIONS=.xml,.json,.csv,.txt
MINIO_COMPRESSION_MIME_TYPES=text/*,application/json,application/xml

# ----------------------------------------------------------
# Política de retenção de dados
# ----------------------------------------------------------
# Para compliance com regulamentação angolana de saúde,
# os dados clínicos devem ser conservados por 10 anos.
# Esta política é aplicada ao nível dos buckets individualmente
# via MinIO Console ou API — não aqui directamente.
# Deixamos o comentário como lembrete para configurar
# após o primeiro arranque.
# CONFIGURAR MANUALMENTE: mc ilm add local/faturas --expiry-days 3650