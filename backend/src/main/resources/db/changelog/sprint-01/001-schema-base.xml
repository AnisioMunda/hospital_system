<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ================================================ -->
    <!-- CHANGESET 1: Criar schema de auditoria           -->
    <!-- ================================================ -->
    <changeSet id="001-00-criar-schema-auditoria" author="hospitalao">
        <sql>CREATE SCHEMA IF NOT EXISTS auditoria;</sql>
        <rollback>
            <sql>DROP SCHEMA IF EXISTS auditoria CASCADE;</sql>
        </rollback>
    </changeSet>


    <!-- ================================================ -->
    <!-- CHANGESET 2: Tipos enumerados globais             -->
    <!-- ================================================ -->
    <changeSet id="001-01-tipos-enum" author="hospitalao">

        <sql>
            DO $$ BEGIN
                CREATE TYPE sexo_enum AS ENUM ('MASCULINO', 'FEMININO');
            EXCEPTION
                WHEN duplicate_object THEN NULL;
            END $$;
        </sql>

        <sql>
            DO $$ BEGIN
                CREATE TYPE estado_registo_enum AS ENUM (
                    'ACTIVO',
                    'INACTIVO',
                    'SUSPENSO'
                );
            EXCEPTION
                WHEN duplicate_object THEN NULL;
            END $$;
        </sql>

        <sql>
            DO $$ BEGIN
                CREATE TYPE tipo_episodio_enum AS ENUM (
                    'URGENCIA',
                    'CONSULTA_EXTERNA',
                    'INTERNAMENTO',
                    'CIRURGIA_AMBULATORIA',
                    'EXAME'
                );
            EXCEPTION
                WHEN duplicate_object THEN NULL;
            END $$;
        </sql>

        <rollback>
            <sql>
                DROP TYPE IF EXISTS tipo_episodio_enum;
                DROP TYPE IF EXISTS estado_registo_enum;
                DROP TYPE IF EXISTS sexo_enum;
            </sql>
        </rollback>
    </changeSet>


    <!-- ================================================ -->
    <!-- CHANGESET 3: Tabela de auditoria                 -->
    <!-- ================================================ -->
    <changeSet id="001-02-tabela-auditoria" author="hospitalao">

        <createTable tableName="auditoria_log" schemaName="auditoria">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="utilizador_id" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="utilizador_nome" type="VARCHAR(200)">
                <constraints nullable="true"/>
            </column>
            <column name="tabela_nome" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="registo_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="operacao" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="dados_anteriores" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="dados_novos" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="ip_origem" type="VARCHAR(45)">
                <constraints nullable="true"/>
            </column>
            <column name="criado_em" type="TIMESTAMP WITH TIME ZONE"
                     defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="auditoria_log"
                     schemaName="auditoria"
                     indexName="idx_audit_tabela_registo">
            <column name="tabela_nome"/>
            <column name="registo_id"/>
        </createIndex>

        <createIndex tableName="auditoria_log"
                     schemaName="auditoria"
                     indexName="idx_audit_criado_em">
            <column name="criado_em"/>
        </createIndex>

        <rollback>
            <dropTable tableName="auditoria_log" schemaName="auditoria"/>
        </rollback>
    </changeSet>

</databaseChangeLog>