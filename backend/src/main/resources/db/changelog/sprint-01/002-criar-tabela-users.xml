        Estes perfis são criados automaticamente — o administrador
        não precisa de os criar manualmente.

        Os UUIDs são fixos (não aleatórios) para que os dados
        iniciais sejam consistentes em qualquer ambiente.
    -->
    <changeSet id="002-06-inserir-roles-base" author="hospitalao">

        <insert tableName="roles">
            <column name="id" value="00000000-0000-0000-0000-000000000001"/>
            <column name="nome" value="ADMIN"/>
            <column name="descricao" value="Administrador do sistema — acesso total"/>
            <column name="activo" valueBoolean="true"/>
