        <insert tableName="roles">
            <column name="id" value="00000000-0000-0000-0000-000000000002"/>
            <column name="nome" value="MEDICO"/>
            <column name="descricao" value="Médico — consultas, prescrições, diagnósticos"/>
            <column name="activo" valueBoolean="true"/>
        </insert>

        <insert tableName="roles">
            <column name="id" value="00000000-0000-0000-0000-000000000003"/>
            <column name="nome" value="ENFERMEIRO"/>
            <column name="descricao" value="Enfermeiro — triagem, internamento, evolução"/>
            <column name="activo" valueBoolean="true"/>
        </insert>

        <insert tableName="roles">
            <column name="id" value="00000000-0000-0000-0000-000000000004"/>
            <column name="nome" value="RECEPCAO"/>
            <column name="descricao" value="Recepcionista — admissão, agendamento, filas"/>
            <column name="activo" valueBoolean="true"/>
        </insert>

        <insert tableName="roles">
            <column name="id" value="00000000-0000-0000-0000-000000000005"/>
            <column name="nome" value="FARMACIA"/>
            <column name="descricao" value="Farmacêutico — dispensação e stock de medicamentos"/>
            <column name="activo" valueBoolean="true"/>
        </insert>

        <insert tableName="roles">
            <column name="id" value="00000000-0000-0000-0000-000000000006"/>
            <column name="nome" value="FINANCEIRO"/>
            <column name="descricao" value="Financeiro — faturação, pagamentos, relatórios"/>
            <column name="activo" valueBoolean="true"/>
        </insert>

        <insert tableName="roles">
            <column name="id" value="00000000-0000-0000-0000-000000000007"/>
            <column name="nome" value="GESTOR"/>
