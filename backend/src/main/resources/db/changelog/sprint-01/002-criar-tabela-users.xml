                    '00000000-0000-0000-0000-000000000001',
                    '00000000-0000-0000-0000-000000000002',
                    '00000000-0000-0000-0000-000000000003',
                    '00000000-0000-0000-0000-000000000004',
                    '00000000-0000-0000-0000-000000000005',
                    '00000000-0000-0000-0000-000000000006',
                    '00000000-0000-0000-0000-000000000007',
                    '00000000-0000-0000-0000-000000000008'
                )</where>
            </delete>
        </rollback>
    </changeSet>


    <!-- ================================================ -->
    <!-- CHANGESET 7: Utilizador admin inicial            -->
    <!-- ================================================ -->
    <!--
        Criar o primeiro utilizador administrador.
        Password: Admin@2024 (hash BCrypt)
        O administrador deve mudar a password no primeiro login.

        COMO GERAR UM HASH BCrypt:
        Em Java: new BCryptPasswordEncoder().encode("Admin@2024")
        Online: https://bcrypt-generator.com (apenas em dev!)
    -->
    <changeSet id="002-07-inserir-admin-inicial" author="hospitalao">

        <insert tableName="users">
            <column name="id" value="00000000-0000-0000-0000-000000000099"/>
            <column name="nome_completo" value="Administrador do Sistema"/>
            <column name="username" value="admin"/>
            <!-- Hash BCrypt de "Admin@2024" -->
            <column name="password_hash" value="$2a$12$N9qo8uLOickgx2ZMRZoMyeIjZAgcfl7p92ldGxad68LJZdL17lhWy"/>
            <column name="email" value="admin@hospitalao.ao"/>
            <column name="estado" value="ACTIVO"/>
            <column name="deve_mudar_password" valueBoolean="true"/>
        </insert>

        <!-- Atribuir o perfil ADMIN ao utilizador admin -->
        <insert tableName="user_roles">
            <column name="user_id" value="00000000-0000-0000-0000-000000000099"/>
            <column name="role_id" value="00000000-0000-0000-0000-000000000001"/>
        </insert>

        <rollback>
            <delete tableName="user_roles">
                <where>user_id = '00000000-0000-0000-0000-000000000099'</where>
            </delete>
